# Copy to .env and fill in. NEVER commit .env.
# Required
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional — defaults shown
UNDERSTUDY_DATA_DIR=~/.understudy
UNDERSTUDY_DB_PATH=~/.understudy/understudy.db
UNDERSTUDY_RETENTION_DAYS=7
UNDERSTUDY_MODEL=claude-sonnet-4-5
UNDERSTUDY_MAX_STEPS=50
UNDERSTUDY_LOG_LEVEL=INFO

# Encryption — leave empty to use the macOS Keychain entry instead.
# UNDERSTUDY_DB_KEY=
